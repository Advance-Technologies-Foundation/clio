<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClioRing.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="520"
             x:Class="ClioRing.Views.RingView"
             x:DataType="vm:RingViewModel"
             x:CompileBindings="True"
             FontFamily="Inter, Segoe UI, sans-serif"
             Foreground="#E6EDF3">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Accent" Color="#F97316" />
        <SolidColorBrush x:Key="IconIdle" Color="#AEB9C6" />
        <SolidColorBrush x:Key="LabelIdle" Color="#8B97A5" />
        <SolidColorBrush x:Key="Success" Color="#3FB950" />
        <SolidColorBrush x:Key="Failure" Color="#F85149" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- ===== Ring node: one calm resting surface, elevation not glow ===== -->
        <Style Selector="Border.node">
            <Setter Property="Background" Value="#0FFFFFFF" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BoxShadow" Value="0 2 8 0 #40000000" />
            <Setter Property="RenderTransform" Value="scale(1)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.22" />
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.16" />
                    <BrushTransition Property="Background" Duration="0:0:0.16" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.13" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.node Path.icon">
            <Setter Property="Stroke" Value="{StaticResource IconIdle}" />
        </Style>

        <!-- Selected environment: restrained persistent treatment (no glow, distinct from run states) -->
        <Style Selector="Border.node.selected">
            <Setter Property="BorderBrush" Value="#80F97316" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Background" Value="#14F97316" />
        </Style>
        <Style Selector="Border.node.selected Path.icon">
            <Setter Property="Stroke" Value="#E0A56A" />
        </Style>

        <!-- Hover: subtle elevation only, no accent glow -->
        <Style Selector="Border.node:pointerover">
            <Setter Property="Background" Value="#17FFFFFF" />
            <Setter Property="BorderBrush" Value="#3AFFFFFF" />
            <Setter Property="BoxShadow" Value="0 4 14 0 #55000000" />
            <Setter Property="RenderTransform" Value="scale(1.05)" />
        </Style>

        <!-- Pressed -->
        <Style Selector="Border.node:pressed">
            <Setter Property="RenderTransform" Value="scale(0.95)" />
        </Style>

        <!-- Keyboard focus: strong, high-contrast ring (accent) — reserved emphasis -->
        <Style Selector="Border.node:focus, Border.node.kbfocus">
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="BorderThickness" Value="2.5" />
            <Setter Property="Background" Value="#22F97316" />
            <Setter Property="BoxShadow" Value="0 0 0 3 #66F97316, 0 6 18 0 #66000000" />
        </Style>
        <Style Selector="Border.node:focus Path.icon, Border.node.kbfocus Path.icon">
            <Setter Property="Stroke" Value="#FFFFFF" />
        </Style>

        <!-- Running: accent border + glow (the one glowing node) -->
        <Style Selector="Border.node.running">
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BoxShadow" Value="0 0 22 2 #80F97316" />
        </Style>
        <Style Selector="Border.node.running Path.icon">
            <Setter Property="Stroke" Value="{StaticResource Accent}" />
        </Style>

        <!-- Success -->
        <Style Selector="Border.node.success">
            <Setter Property="BorderBrush" Value="{StaticResource Success}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BoxShadow" Value="0 0 16 1 #553FB950" />
        </Style>
        <Style Selector="Border.node.success Path.icon">
            <Setter Property="Stroke" Value="{StaticResource Success}" />
        </Style>

        <!-- Failure -->
        <Style Selector="Border.node.failure">
            <Setter Property="BorderBrush" Value="{StaticResource Failure}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BoxShadow" Value="0 0 16 1 #55F85149" />
        </Style>
        <Style Selector="Border.node.failure Path.icon">
            <Setter Property="Stroke" Value="{StaticResource Failure}" />
        </Style>

        <!-- Destructive hint (persistent) -->
        <Style Selector="Border.node.destructive">
            <Setter Property="BorderBrush" Value="#55F85149" />
        </Style>

        <!-- Node labels + captions -->
        <Style Selector="TextBlock.nodelabel">
            <Setter Property="Foreground" Value="{StaticResource LabelIdle}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.envlabel">
            <Setter Property="Foreground" Value="#D6DEE7" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <!-- Buttons -->
        <Style Selector="Button.pill">
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="#1FFFFFFF" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E6EDF3" />
        </Style>
        <!-- 'primary' (not 'accent': FluentTheme reserves the 'accent' Button class for the system blue) -->
        <Style Selector="Button.pill.primary">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="#0B0F14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <!-- Neutral high-contrast (Cancel while running) — never red -->
        <Style Selector="Button.pill.strong">
            <Setter Property="Background" Value="#33FFFFFF" />
            <Setter Property="BorderBrush" Value="#5AFFFFFF" />
            <Setter Property="Foreground" Value="#F2F6FA" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.pill.danger">
            <Setter Property="Background" Value="{StaticResource Failure}" />
            <Setter Property="Foreground" Value="#0B0F14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.icon">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1FFFFFFF" />
        </Style>

        <!-- Collapsed output bar expand button (focusable, left-aligned) -->
        <Style Selector="Button.outbar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.outbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1FFFFFFF" />
        </Style>

        <!-- Build-identity badge: tiny, dim, unobtrusive; click to copy full identity -->
        <Style Selector="Button.badge">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Foreground" Value="#46505C" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.badge:pointerover">
            <Setter Property="Foreground" Value="#8B97A5" />
        </Style>
        <Style Selector="Button.badge:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- Transparent hit target over the hub (opens the env palette) -->
        <Style Selector="Button.hubhit">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="44" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.hubhit:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>

        <!-- Filter chips (All / Local / Cloud) -->
        <Style Selector="Button.chip">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Background" Value="#16FFFFFF" />
            <Setter Property="BorderBrush" Value="#2AFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#C2CCD6" />
        </Style>
        <Style Selector="Button.chip.active">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="#0B0F14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Palette rows -->
        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#6E7A88" />
            <Setter Property="Margin" Value="2,6,0,2" />
        </Style>
        <Style Selector="TextBlock.badge">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#9FB0C0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.pin">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Foreground" Value="#5A6673" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style Selector="Button.pin.pinned">
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
        </Style>
        <Style Selector="Button.pin:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1FFFFFFF" />
        </Style>
        <!-- ListBox rows: compact, flat -->
        <Style Selector="ListBox.envlist">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ListBox.envlist ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <!-- High-contrast keyboard highlight band (VM-driven, not Fluent's faint tint) -->
        <Style Selector="Border.row">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Border.row.highlighted">
            <Setter Property="Background" Value="#3DF97316" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Main layout: fixed ring region (row 0) + drawer reserved below (row 1). -->
        <Grid RowDefinitions="Auto,Auto">

            <!-- Fixed-geometry ring region -->
            <Border Grid.Row="0"
                    Width="{Binding Diameter}"
                    Height="{Binding Diameter}"
                    HorizontalAlignment="Center">
                <Panel>
                    <!-- very faint orbit guides (quiet default) -->
                    <Ellipse Width="300" Height="300" Stroke="#12FFFFFF" StrokeThickness="1"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="164" Height="164" Stroke="#0EFFFFFF" StrokeThickness="1"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <Canvas x:Name="RingCanvas"
                            Width="{Binding Diameter}"
                            Height="{Binding Diameter}" />

                    <!-- Central hub = environment selector: shows the selected env; click/type opens palette -->
                    <Border Width="88" Height="88" CornerRadius="44"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#12161F"
                            BorderBrush="#40F97316" BorderThickness="1.5">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                            <TextBlock Text="clio" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedEnvironmentName}" FontSize="14"
                                       FontWeight="SemiBold" Foreground="#E0A56A" MaxWidth="78"
                                       TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="switch ▾" FontSize="9"
                                       Foreground="#7C8896"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Button Classes="hubhit" x:Name="HubButton" Width="88" Height="88"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Command="{Binding OpenPickerCommand}"
                            AutomationProperties.Name="{Binding SelectedEnvironmentAccessibleName}"
                            ToolTip.Tip="Select environment (click or start typing)" />

                    <!-- Build-identity badge (bottom-left corner; click to copy full identity) -->
                    <Button Classes="badge" x:Name="BuildBadgeButton"
                            HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Margin="6,0,0,4"
                            Content="{Binding BuildBadge}"
                            AutomationProperties.Name="Build identity (click to copy)"
                            ToolTip.Tip="{Binding BuildIdentity}" />
                </Panel>
            </Border>

            <!-- Output bottom-sheet: expands into reserved space, never reflows the ring -->
            <Border Grid.Row="1"
                    IsVisible="{Binding IsOutputOpen}"
                    Margin="14,0,14,14"
                    Background="#0D1117"
                    BorderBrush="#26FFFFFF" BorderThickness="1"
                    CornerRadius="12">
                <Grid RowDefinitions="Auto,Auto" Margin="12">
                    <!-- Header: command + end-state badge + collapse -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding CommandHeader}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="12" Foreground="#C9D4E0"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <Border Grid.Column="1"
                                IsVisible="{Binding HasOutcomeBadge}"
                                Background="{Binding OutcomeBrush}"
                                CornerRadius="5" Padding="8,2" Margin="6,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding OutcomeLabel}"
                                       FontSize="10" FontWeight="Bold" Foreground="#0B0F14" />
                        </Border>
                        <!-- Cancel while running: neutral high-contrast (never red) -->
                        <Button Grid.Column="2" Classes="pill strong"
                                Content="Cancel" Command="{Binding CancelCommand}"
                                IsVisible="{Binding IsBusy}" VerticalAlignment="Center" />
                        <!-- Completion Close: explicit, takes keyboard focus on completion -->
                        <Button Grid.Column="2" x:Name="DrawerCloseButton" Classes="pill strong"
                                Content="Close" Command="{Binding CollapseOutputCommand}"
                                IsVisible="{Binding !IsBusy}" VerticalAlignment="Center" />
                        <Button Grid.Column="3" Classes="icon"
                                Command="{Binding CollapseOutputCommand}"
                                ToolTip.Tip="Collapse" VerticalAlignment="Center" Margin="4,0,0,0">
                            <Path Data="M6 9 L12 15 L18 9" Stroke="#AEB9C6" StrokeThickness="1.8"
                                  StrokeLineCap="Round" StrokeJoin="Round" Width="20" Height="20"
                                  Stretch="Uniform" />
                        </Button>
                    </Grid>

                    <!-- Output -->
                    <Border Grid.Row="1" Background="#080B0F" CornerRadius="8" Height="176">
                        <ScrollViewer x:Name="OutputScroller"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <SelectableTextBlock Text="{Binding OutputText}"
                                                 FontFamily="Cascadia Mono, Consolas, monospace"
                                                 FontSize="12" Foreground="#C9D4E0" Padding="10" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- Collapsed output bar: keeps the last output reachable (fixes the lost-output bug).
                 Click / Enter re-expands the SAME buffer; Cancel + state stay reachable while running. -->
            <Border Grid.Row="1"
                    IsVisible="{Binding IsOutputCollapsed}"
                    Margin="14,0,14,14"
                    Background="#0D1117"
                    BorderBrush="#26FFFFFF" BorderThickness="1"
                    CornerRadius="10">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="6">
                    <Button Grid.Column="0" x:Name="OutputBarButton" Classes="outbar"
                            Command="{Binding ExpandOutputCommand}"
                            ToolTip.Tip="Expand output">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Path Data="M6 15 L12 9 L18 15" Stroke="#AEB9C6" StrokeThickness="1.8"
                                  StrokeLineCap="Round" StrokeJoin="Round" Width="16" Height="16"
                                  Stretch="Uniform" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CommandHeader}"
                                       FontFamily="Cascadia Mono, Consolas, monospace"
                                       FontSize="12" Foreground="#C9D4E0" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" MaxWidth="220" />
                        </StackPanel>
                    </Button>
                    <Border Grid.Column="1"
                            IsVisible="{Binding HasOutcomeBadge}"
                            Background="{Binding OutcomeBrush}"
                            CornerRadius="5" Padding="8,2" Margin="6,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding OutcomeLabel}"
                                   FontSize="10" FontWeight="Bold" Foreground="#0B0F14" />
                    </Border>
                    <!-- Cancel remains reachable while running, even collapsed -->
                    <Button Grid.Column="2" Classes="pill strong"
                            Content="Cancel" Command="{Binding CancelCommand}"
                            IsVisible="{Binding IsBusy}" VerticalAlignment="Center" />
                    <!-- Clear (dismiss the bar); next run replaces it anyway -->
                    <Button Grid.Column="3" Classes="icon"
                            Command="{Binding ClearOutputCommand}"
                            IsVisible="{Binding !IsBusy}"
                            ToolTip.Tip="Clear output" VerticalAlignment="Center" Margin="4,0,0,0">
                        <Path Data="M6 6 L18 18 M18 6 L6 18" Stroke="#AEB9C6" StrokeThickness="1.6"
                              StrokeLineCap="Round" Width="14" Height="14" Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Destructive / confirm dialog overlay (does not shift ring geometry) -->
        <Border IsVisible="{Binding HasPendingConfirm}"
                Background="#B0060911">
            <Border Background="#141A24" BorderBrush="#33FFFFFF" BorderThickness="1"
                    CornerRadius="12" Padding="20" MaxWidth="320"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BoxShadow="0 20 50 0 #90000000">
                <StackPanel Spacing="16">
                    <TextBlock Text="Confirm action" FontSize="15" FontWeight="Bold" />
                    <TextBlock Text="{Binding ConfirmMessage}" TextWrapping="Wrap"
                               Foreground="#C2CCD6" />
                    <!-- Explicit, prominent consequence line for irreversible actions (empty = hidden). -->
                    <Border IsVisible="{Binding HasConfirmConsequence}"
                            Background="#3A1618" BorderBrush="#F85149" BorderThickness="1"
                            CornerRadius="6" Padding="10,8" Margin="0,2,0,0">
                        <TextBlock Text="{Binding ConfirmConsequence}" TextWrapping="Wrap"
                                   FontWeight="SemiBold" Foreground="#FF9A93" />
                    </Border>
                    <!-- Typed-confirm gate: irreversible actions require typing the exact env name. -->
                    <StackPanel Spacing="6" IsVisible="{Binding RequiresTypedConfirm}">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#F5B5B2"
                                   Text="{Binding ConfirmExpected, StringFormat='To confirm, type the environment name exactly: {0}'}" />
                        <TextBox x:Name="ConfirmTypedBox"
                                 Text="{Binding ConfirmInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="{Binding ConfirmExpected}"
                                 AcceptsReturn="False"
                                 AutomationProperties.Name="Type the environment name to confirm" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <Button x:Name="ConfirmCancelButton" Classes="pill strong"
                                Content="Cancel" Command="{Binding DismissConfirmCommand}" />
                        <Button Classes="pill danger" Content="Run" Command="{Binding ConfirmCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Non-modal top notices (ring stays usable) -->
        <StackPanel VerticalAlignment="Top" Margin="18,12" Spacing="8">
            <!-- actions.json load/validation error (red; names the offending action/field) -->
            <Border IsVisible="{Binding HasCatalogError}"
                    Background="#2A0F0F" BorderBrush="#F85149" BorderThickness="1"
                    CornerRadius="8" Padding="12,9"
                    BoxShadow="0 8 24 0 #80000000">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                            Background="#F85149" VerticalAlignment="Top" Margin="0,4,10,0" />
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Invalid actions.json" FontWeight="Bold" Foreground="#F5B5B2" />
                        <TextBlock Text="{Binding CatalogError}" TextWrapping="Wrap"
                                   Foreground="#E6C4C2" FontSize="12" Margin="0,2,0,0" />
                    </StackPanel>
                    <Button Grid.Column="2" Classes="pill strong" Content="Details"
                            Command="{Binding OpenSettingsCommand}" VerticalAlignment="Center"
                            Margin="10,0,0,0" />
                </Grid>
            </Border>

            <!-- Cross-build notice: a different clio-ring build is already running elsewhere -->
            <Border IsVisible="{Binding HasCrossBuildNotice}"
                    Background="#2A1C0B" BorderBrush="#F5A524" BorderThickness="1"
                    CornerRadius="8" Padding="12,9"
                    BoxShadow="0 8 24 0 #80000000">
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                            Background="#F5A524" VerticalAlignment="Top" Margin="0,4,10,0" />
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="A different clio ring build is already running" FontWeight="Bold" Foreground="#F5D9A8" />
                        <TextBlock Text="{Binding CrossBuildNotice}" TextWrapping="Wrap"
                                   Foreground="#E6D3B0" FontSize="12" Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Hotkey-conflict notice -->
            <Border IsVisible="{Binding HasHotkeyNotice}"
                    Background="#2A1C0B" BorderBrush="#F5A524" BorderThickness="1"
                    CornerRadius="8" Padding="12,9"
                    BoxShadow="0 8 24 0 #80000000">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                            Background="#F5A524" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Grid.Column="1" Text="{Binding HotkeyNotice}"
                               VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#F0D9B5" />
                    <Button Grid.Column="2" Classes="pill primary" Content="Change shortcut"
                            Command="{Binding OpenSettingsCommand}" VerticalAlignment="Center"
                            Margin="10,0,0,0" />
                </Grid>
            </Border>
        </StackPanel>

        <!-- Settings / hotkey overlay -->
        <Border IsVisible="{Binding ShowSettings}" Background="#B0060911">
            <Border Background="#141A24" BorderBrush="#33FFFFFF" BorderThickness="1"
                    CornerRadius="12" Padding="20" MaxWidth="380" MaxHeight="560"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BoxShadow="0 20 50 0 #90000000">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="14">
                    <TextBlock Text="Settings" FontSize="15" FontWeight="Bold" />
                    <StackPanel Spacing="3">
                        <TextBlock Text="Current shortcut" FontSize="11" Foreground="#8B97A5" />
                        <TextBlock Text="{Binding HotkeyDisplay}" FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource Accent}" />
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="#C2CCD6"
                               Text="To change it, edit the &quot;Hotkey&quot; value in the config file below (e.g. Ctrl+Alt+C, Ctrl+Shift+Backquote) and relaunch clio ring." />
                    <SelectableTextBlock Text="{Binding ConfigPath}"
                                         FontFamily="Cascadia Mono, Consolas, monospace"
                                         FontSize="11" Foreground="#9FB0C0" TextWrapping="Wrap" />

                    <!-- Connected clio + dev-build override -->
                    <Border Background="#0F1622" BorderBrush="#26FFFFFF" BorderThickness="1"
                            CornerRadius="8" Padding="12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Connected clio" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#C2CCD6" />
                            <SelectableTextBlock Text="{Binding ClioSettings.ConnectedClioIdentity}"
                                                 FontFamily="Cascadia Mono, Consolas, monospace"
                                                 FontSize="11" Foreground="#9FB0C0" TextWrapping="Wrap" />
                            <Border IsVisible="{Binding ClioSettings.IsDevOverrideActive}"
                                    Background="#2A1C0B" BorderBrush="#F5A524" BorderThickness="1"
                                    CornerRadius="6" Padding="8,4" HorizontalAlignment="Left">
                                <TextBlock Text="Using your dev clio build" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#F5D9A8" />
                            </Border>
                            <TextBlock Text="Point the ring at a dev clio build (clio.dll or clio.exe). Leave blank to use the normal clio."
                                       FontSize="11" Foreground="#8B97A5" TextWrapping="Wrap" />
                            <TextBox x:Name="DevClioPathBox"
                                     Text="{Binding ClioSettings.DevClioPathInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="C:\Projects\clio\clio\bin\Debug\net10.0\clio.dll"
                                     AcceptsReturn="False"
                                     FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                     AutomationProperties.Name="Dev clio build path" />
                            <SelectableTextBlock IsVisible="{Binding ClioSettings.HasValidationError}"
                                                 Text="{Binding ClioSettings.ValidationMessage}"
                                                 FontSize="11" Foreground="#F5A5A2" TextWrapping="Wrap" />
                            <SelectableTextBlock IsVisible="{Binding ClioSettings.HasStatusMessage}"
                                                 Text="{Binding ClioSettings.StatusMessage}"
                                                 FontSize="11" Foreground="#8FCF9A" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button x:Name="DevClioClearButton" Classes="pill strong" Content="Use normal clio"
                                        Command="{Binding ClioSettings.ClearDevClioOverrideCommand}" />
                                <Button x:Name="DevClioSaveButton" Classes="pill primary" Content="Save"
                                        Command="{Binding ClioSettings.SaveDevClioOverrideCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="3">
                        <TextBlock Text="Build" FontSize="11" Foreground="#8B97A5" />
                        <SelectableTextBlock Text="{Binding BuildIdentity}"
                                             FontFamily="Cascadia Mono, Consolas, monospace"
                                             FontSize="11" Foreground="#9FB0C0" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="3" IsVisible="{Binding HasCatalogError}">
                        <TextBlock Text="Configuration error (actions.json)" FontSize="11" Foreground="#F5A5A2" />
                        <SelectableTextBlock Text="{Binding CatalogError}"
                                             FontFamily="Cascadia Mono, Consolas, monospace"
                                             FontSize="11" Foreground="#E6C4C2" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Classes="pill strong" Content="Close" HorizontalAlignment="Right"
                            Command="{Binding CloseSettingsCommand}" />
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>

        <!-- Environment palette overlay (search-first selector) -->
        <Border IsVisible="{Binding IsPickerOpen}" Background="#C0060911">
            <Border Background="#141A24" BorderBrush="#33FFFFFF" BorderThickness="1"
                    CornerRadius="12" Padding="16" Width="380" MaxHeight="440"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BoxShadow="0 20 50 0 #90000000">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <!-- Title + location filters -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <TextBlock Grid.Column="0" Text="Select environment"
                                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button Classes="chip" Content="↻ Refresh"
                                    Command="{Binding RefreshEnvironmentsCommand}"
                                    IsEnabled="{Binding !IsRefreshingEnvironments}"
                                    ToolTip.Tip="Reload registered environments from clio" />
                            <Button Classes="chip" Classes.active="{Binding IsFilterAll}" Content="All"
                                    Command="{Binding SetFilterCommand}" CommandParameter="all" />
                            <Button Classes="chip" Classes.active="{Binding IsFilterLocal}" Content="Local"
                                    Command="{Binding SetFilterCommand}" CommandParameter="local" />
                            <Button Classes="chip" Classes.active="{Binding IsFilterCloud}" Content="Cloud"
                                    Command="{Binding SetFilterCommand}" CommandParameter="cloud" />
                        </StackPanel>
                    </Grid>

                    <!-- Search with clear affordance -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <TextBox x:Name="EnvSearchBox"
                                 Text="{Binding SearchQuery, Mode=TwoWay}"
                                 PlaceholderText="Type to filter by name or host…" />
                        <Button Classes="icon" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,0,4,0" Command="{Binding ClearQueryCommand}"
                                IsVisible="{Binding HasQuery}"
                                ToolTip.Tip="Clear">
                            <Path Data="M6 6 L18 18 M18 6 L6 18" Stroke="#AEB9C6" StrokeThickness="1.6"
                                  StrokeLineCap="Round" Width="14" Height="14" Stretch="Uniform" />
                        </Button>
                    </Grid>

                    <!-- Results -->
                    <Panel Grid.Row="2">
                        <ListBox x:Name="EnvList" Classes="envlist"
                                 IsVisible="{Binding !HasNoMatches}"
                                 ItemsSource="{Binding FilteredEnvironments}"
                                 SelectedIndex="{Binding HighlightedIndex, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:EnvRowViewModel">
                                    <StackPanel>
                                        <TextBlock Classes="section" Text="{Binding SectionLabel}"
                                                   IsVisible="{Binding HasSection}" />
                                        <Border Classes="row" Classes.highlighted="{Binding IsHighlighted}">
                                            <Grid ColumnDefinitions="*,Auto,Auto">
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#E6EDF3" VerticalAlignment="Center" />
                                                        <TextBlock Classes="badge" Text="{Binding Host}"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="150"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock Classes="badge" Text="{Binding Framework}" FontSize="9"
                                                               Foreground="#6E7A88" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Classes="badge" Margin="6,0"
                                                           Text="{Binding Location}" VerticalAlignment="Center" />
                                                <!-- Pin: small glyph, tall hit target (>= row height) -->
                                                <Button Grid.Column="2" Classes="pin"
                                                        Classes.pinned="{Binding IsPinned}"
                                                        Content="★" MinWidth="36"
                                                        VerticalAlignment="Stretch" VerticalContentAlignment="Center"
                                                        Command="{Binding TogglePinCommand}"
                                                        CommandParameter="{Binding Name}"
                                                        ToolTip.Tip="Pin / unpin (Ctrl+P)" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Empty state -->
                        <StackPanel IsVisible="{Binding HasNoMatches}" Spacing="10"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding NoMatchText}" Foreground="#8B97A5"
                                       HorizontalAlignment="Center" />
                            <Button Classes="pill" Content="Clear search" HorizontalAlignment="Center"
                                    Command="{Binding ClearQueryCommand}" />
                        </StackPanel>
                    </Panel>

                    <TextBlock Grid.Row="3" Margin="0,8,0,0" FontSize="11" Foreground="#6E7A88"
                               Text="↑↓ navigate · Enter select · Ctrl+P pin · Esc clear/close" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
