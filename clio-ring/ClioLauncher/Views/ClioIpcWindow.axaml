<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ClioLauncher.ViewModels"
        xmlns:ipc="using:ClioLauncher.Ipc"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ClioLauncher.Views.ClioIpcWindow"
        x:DataType="vm:ClioIpcViewModel"
        Title="clio IPC (experimental)"
        Icon="/Assets/clio-ring.ico"
        Width="820" Height="620"
        WindowStartupLocation="CenterScreen"
        Background="#0E1117">

    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Header: connection + handshake -->
        <Border Grid.Row="0" CornerRadius="10" Padding="14" Background="#161C26" BorderBrush="#26FFFFFF" BorderThickness="1">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="clio MCP over stdio" FontSize="16" FontWeight="SemiBold" Foreground="#E6EDF3" VerticalAlignment="Center"/>
                    <Border CornerRadius="6" Padding="6,2" VerticalAlignment="Center"
                            Background="#1F6F3D" IsVisible="{Binding IsConnected}">
                        <TextBlock Text="connected" Foreground="#DFFFE8" FontSize="11"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Connect + load catalog" Command="{Binding ConnectAndLoadCommand}" IsEnabled="{Binding !IsBusy}"/>
                    <Button Content="Restart child" Command="{Binding RestartCommand}" IsEnabled="{Binding !IsBusy}"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4" Margin="0,10,0,0">
                    <!-- Self-identifying connection: "clio 8.1.0.77 · C:\...\clio.dll" -->
                    <TextBlock Foreground="#C9D1D9" FontSize="12" FontFamily="Cascadia Code,Consolas,monospace"
                               Text="{Binding ConnectionSummary}" TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Foreground="#8B949E" FontSize="12">
                            <Run Text="State:"/><Run Text=" "/><Run Text="{Binding ConnectionState}"/>
                        </TextBlock>
                        <TextBlock Foreground="#58A6FF" FontSize="12" FontWeight="SemiBold" Text="{Binding CatalogSummary}"/>
                        <TextBlock Foreground="#8B949E" FontSize="12">
                            <Run Text="Caps:"/><Run Text=" "/><Run Text="{Binding Capabilities}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,12,0,8">
            <TextBox Grid.Column="0" PlaceholderText="Search the full command catalog (name or purpose)…"
                     Text="{Binding SearchText}" />
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#8B949E" FontSize="12">
                <Run Text="{Binding CatalogCount}"/><Run Text=" shown"/>
            </TextBlock>
        </Grid>

        <!-- Env controls (read-only) -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,220,Auto,Auto" Margin="0,0,0,10">
            <TextBlock Grid.Column="0" Text="Environment:" VerticalAlignment="Center" Foreground="#C9D1D9" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" PlaceholderText="e.g. ve or d1" Text="{Binding SelectedEnvironment}"/>
            <Button Grid.Column="2" Content="list-environments" Margin="8,0,0,0"
                    Command="{Binding RunListEnvironmentsCommand}" IsEnabled="{Binding !IsBusy}"/>
            <Button Grid.Column="3" Content="get-info" Margin="8,0,0,0"
                    Command="{Binding RunGetInfoCommand}" IsEnabled="{Binding !IsBusy}"/>
        </Grid>

        <!-- Catalog list (or the incompatible-clio panel) -->
        <Border Grid.Row="3" CornerRadius="10" Background="#0B0E14" BorderBrush="#26FFFFFF" BorderThickness="1">
            <Panel>
                <!-- Incompatible clio: explicit panel with the actual path + version, never a silent 0. -->
                <Border IsVisible="{Binding IsIncompatible}" Padding="20" Background="#2D1618"
                        CornerRadius="10" VerticalAlignment="Top" Margin="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="⚠ Incompatible clio" Foreground="#FF9EA6" FontSize="15" FontWeight="SemiBold"/>
                        <SelectableTextBlock Text="{Binding IncompatibleMessage}" Foreground="#E6C9CB"
                                             FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
                    </StackPanel>
                </Border>

                <ListBox ItemsSource="{Binding Catalog}" Background="Transparent" Padding="4"
                         IsVisible="{Binding !IsIncompatible}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="ipc:ClioCatalogEntry">
                            <Grid ColumnDefinitions="230,*,Auto,120" Margin="4">
                                <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#79C0FF" FontFamily="Cascadia Code,Consolas,monospace" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Purpose}" Foreground="#C9D1D9" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                <Border Grid.Column="2" CornerRadius="6" Padding="6,2" Background="#7A1F27" VerticalAlignment="Center"
                                        IsVisible="{Binding Destructive}">
                                    <TextBlock Text="destructive" Foreground="#FFD7DA" FontSize="11"/>
                                </Border>
                                <!-- Read-only tools get a Run button; destructive tools show a disabled note. -->
                                <Button Grid.Column="3" Content="Run (read-only)" FontSize="11" VerticalAlignment="Center"
                                        HorizontalAlignment="Right" IsVisible="{Binding !Destructive}"
                                        Command="{Binding $parent[ListBox].((vm:ClioIpcViewModel)DataContext).RunEntryCommand}"
                                        CommandParameter="{Binding}"/>
                                <TextBlock Grid.Column="3" Text="disabled in proof" FontSize="11" FontStyle="Italic"
                                           Foreground="#6E7681" VerticalAlignment="Center" HorizontalAlignment="Right"
                                           IsVisible="{Binding Destructive}"
                                           ToolTip.Tip="destructive — disabled in proof"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Panel>
        </Border>

        <!-- Output -->
        <Border Grid.Row="4" CornerRadius="10" Background="#0B0E14" BorderBrush="#26FFFFFF" BorderThickness="1"
                Margin="0,12,0,0" Padding="12" MaxHeight="180">
            <ScrollViewer>
                <SelectableTextBlock Text="{Binding Output}" Foreground="#C9D1D9"
                                     FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
