{
	"components": [
		{
			"componentType": "crt.Scaffold",
			"description": "Mandatory root element for every mobile page. Provides the top navigation bar (title, leading, actions) and the page body (items). All other content goes inside it. Templates already insert one Scaffold — do NOT insert a second one; use merge to patch it.",
			"inputs": {
				"title": {
					"type": "string",
					"description": "Page title. Typically '$PageTitle' attribute reference."
				},
				"leading": {
					"type": "array",
					"description": "Left-side navigation items (back/cancel buttons)."
				},
				"actions": {
					"type": "array",
					"description": "Right-side action items (save button, search button)."
				},
				"floatAction": {
					"type": "object",
					"description": "Single floating action button (crt.FloatingActionButton). Set to null when not needed."
				},
				"items": {
					"type": "array",
					"description": "Page body — array of container/component references."
				},
				"header": {
					"type": "array",
					"description": "Header child components."
				},
				"fullScreen": {
					"type": "boolean",
					"description": "Full-screen mode."
				},
				"useSurface": {
					"type": "boolean",
					"description": "Use surface background color."
				},
				"leadingWidth": {
					"type": "number",
					"description": "Leading area width."
				}
			}
		},
		{
			"componentType": "crt.GridContainer",
			"description": "CSS-grid layout container. Supports the 'adaptive' property for per-breakpoint column overrides (small/medium/large).",
			"inputs": {
				"columns": {
					"type": "string",
					"default": "1fr",
					"description": "CSS grid-template-columns. Single string '1fr 1fr' or array ['1fr','1fr']. Runtime accepts both formats."
				},
				"adaptive": {
					"type": "object",
					"description": "Per-breakpoint column overrides. Keys: 'small' (phone portrait), 'medium' (landscape/tablet portrait), 'large' (tablet landscape). Example: {\"small\":{\"columns\":\"1fr\"},\"medium\":{\"columns\":\"1fr 1fr\"}}."
				},
				"gap": {
					"type": "object",
					"description": "Row and column gap config."
				},
				"padding": {
					"type": "object",
					"description": "Padding config: { top, right, bottom, left }."
				},
				"borderRadius": {
					"type": "object",
					"description": "Border radius config."
				},
				"justifyItems": {
					"type": "string",
					"description": "CSS-like justify-items."
				},
				"alignItems": {
					"type": "string",
					"description": "CSS-like align-items."
				},
				"items": {
					"type": "array",
					"description": "Child components."
				},
				"color": {
					"type": "string",
					"values": ["default", "primary"],
					"description": "Background color. Use 'primary' for profile/area highlight."
				}
			}
		},
		{
			"componentType": "crt.FlexContainer",
			"description": "Flexbox layout container for linear horizontal or vertical arrangement of items.",
			"inputs": {
				"direction": {
					"type": "string",
					"default": "column",
					"values": ["row", "column"],
					"description": "Flex direction."
				},
				"justifyContent": {
					"type": "string",
					"default": "start",
					"values": ["start", "end", "center", "spaceBetween", "spaceAround", "spaceEvenly"],
					"description": "Main axis alignment."
				},
				"alignItems": {
					"type": "string",
					"default": "stretch",
					"values": ["start", "end", "center", "stretch"],
					"description": "Cross axis alignment."
				},
				"wrap": {
					"type": "string",
					"default": "noWrap",
					"values": ["noWrap", "wrap"],
					"description": "Flex wrapping behavior."
				},
				"gap": {
					"type": "number",
					"description": "Gap between items in pixels."
				},
				"padding": {
					"type": "object",
					"description": "Padding config: { top, right, bottom, left }."
				},
				"color": {
					"type": "string",
					"description": "Background color."
				},
				"borderRadius": {
					"type": "object",
					"description": "Border radius config."
				},
				"scrollable": {
					"type": "boolean",
					"default": false,
					"description": "Enable scrolling."
				},
				"items": {
					"type": "array",
					"description": "Child components."
				}
			}
		},
		{
			"componentType": "crt.TabPanel",
