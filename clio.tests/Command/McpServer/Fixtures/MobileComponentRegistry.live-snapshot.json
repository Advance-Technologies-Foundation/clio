		{
			"componentType": "crt.Button",
			"description": "Tappable button for triggering actions, navigation, and menus.",
			"inputs": {
				"caption": {
					"type": "string",
					"description": "Button label text."
				},
				"icon": {
					"type": "string",
					"description": "Icon identifier."
				},
				"iconPosition": {
					"type": "string",
					"description": "Icon position relative to caption."
				},
				"color": {
					"type": "string",
					"description": "Color scheme."
				},
				"size": {
					"type": "string",
					"description": "Size variant."
				},
				"menuItems": {
					"type": "array",
					"description": "Child crt.MenuItem entries for dropdown/modal menu."
				},
				"menuTitle": {
					"type": "string",
					"description": "Title shown on the menu picker."
				},
				"visible": {
					"type": "string",
					"description": "Visibility binding, e.g. '$CardState | crt.IsEqual : \\'edit\\''."
				}
			},
			"outputs": {
				"clicked": {
					"type": "RequestBindingConfig",
					"description": "Request descriptor fired on tap."
				}
			}
		},
		{
			"componentType": "crt.FloatingActionButton",
			"description": "Single floating action button attached to crt.Scaffold.floatAction. Mobile-specific. Allowed parent: crt.Scaffold.",
			"inputs": {
				"icon": {
					"type": "string",
					"description": "Icon identifier."
