# Pin test fixtures that are compared byte-for-byte against serialized output to LF,
# so the working-tree line endings do not depend on each machine's core.autocrlf.
# The clio YAML serializer emits Environment.NewLine (CRLF on Windows); tests normalize
# line endings before comparing, and these fixtures stay LF in git to avoid churn.
clio.tests/Examples/**/*.yaml text eol=lf
clio.tests/Examples/**/*.yml  text eol=lf

# Theme templates feed ThemeCssBuilder (which normalizes them to LF) and the byte-compared
# theme-css golden; pin both to LF so the parity gate never depends on each machine's core.autocrlf.
clio/tpl/themes/**/*.tpl                   text eol=lf
clio.tests/Theming/Fixtures/*.json         text eol=lf

# The ClioStageEvent cross-repo contract fixture (story ring-guided-deploy-1) is compared
# byte-for-byte against System.Text.Json output and mirrored byte-identically into the Ring
# repo; pin it to LF so the parity gate never depends on each machine's core.autocrlf.
clio.tests/Command/McpServer/Fixtures/ClioStageEvent.contract.ndjson text eol=lf
